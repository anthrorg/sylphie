# ==========================================
# Sylphie Environment Configuration
# ==========================================
# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit credentials.
# Every variable used by the application is documented here.

# --- Application ---
# Port where the NestJS backend listens for HTTP requests
APP_PORT=3000
# Environment: development, staging, production
APP_ENV=development
# Log level: error, warn, info, debug, verbose
APP_LOG_LEVEL=debug
# Session identifier for this running instance
SESSION_ID=dev-session-001

# --- Neo4j (World Knowledge Graph) ---
# The WKG is the architectural center of gravity. All subsystems read from or
# write to it. Neo4j Community Edition, no clustering.
# Bolt protocol connection string. Neo4j Bolt protocol listens on port 7687 by default.
NEO4J_URI=bolt://localhost:7687
# Neo4j administrative user (created with NEO4J_AUTH env var in docker-compose)
NEO4J_USER=neo4j
# Neo4j administrative user password
NEO4J_PASSWORD=sylphie_dev
# Database name within Neo4j (default is "neo4j" for community edition)
NEO4J_DATABASE=neo4j
# Max concurrent connections to Neo4j. Tune based on workload and cluster size.
NEO4J_MAX_CONNECTION_POOL_SIZE=50
# Timeout in milliseconds for acquiring a connection from the pool
NEO4J_CONNECTION_TIMEOUT_MS=5000

# --- TimescaleDB (Event Backbone) ---
# The event backbone. All five subsystems write here. Partitioned hypertable
# with 90-day raw retention and 7-day compression. Port 5433 to avoid conflicts.
# Hostname/IP where TimescaleDB is reachable. Inside docker-compose: "timescaledb"
TIMESCALE_HOST=localhost
# Port where TimescaleDB (PostgreSQL) listens. Default 5432 in container, mapped to 5433 on host.
TIMESCALE_PORT=5433
# Database name for event storage
TIMESCALE_DB=sylphie_events
# User with read-write access to events table
TIMESCALE_USER=sylphie
# Password for TIMESCALE_USER
TIMESCALE_PASSWORD=sylphie_events_dev
# Max concurrent connections to TimescaleDB. Tune based on event volume and subsystem parallelism.
TIMESCALE_MAX_CONNECTIONS=20
# Timeout in milliseconds for idle connections before they are closed
TIMESCALE_IDLE_TIMEOUT_MS=30000
# Timeout in milliseconds for acquiring a connection from the pool
TIMESCALE_CONNECTION_TIMEOUT_MS=5000
# Days of raw data to retain before compression (0 = no compression)
TIMESCALE_RETENTION_DAYS=90
# Days after which hypertable data is compressed for cold storage
TIMESCALE_COMPRESSION_DAYS=7

# --- PostgreSQL System DB (Drive Rules, Settings, Users) ---
# Stores what Sylphie should be unaware of: drive rules, system settings,
# guardian audit log. Two separate connection pools with different privileges.
# Port 5434 to avoid conflict with TimescaleDB on 5433.

# Hostname/IP where PostgreSQL (system database) is reachable. Inside docker-compose: "postgres"
POSTGRES_HOST=localhost
# Port where PostgreSQL listens. Default 5432 in container, mapped to 5434 on host.
POSTGRES_PORT=5434
# Database name for system metadata
POSTGRES_DB=sylphie_system

# Admin pool — used for schema migrations and guardian-approved rule changes.
# This user has full DDL and DML privileges. Never use in the runtime hot path.
# Username for the administrative PostgreSQL user. Created by docker-compose via POSTGRES_USER.
POSTGRES_ADMIN_USER=sylphie_admin
# Password for the administrative PostgreSQL user. Created by docker-compose via POSTGRES_PASSWORD.
POSTGRES_ADMIN_PASSWORD=sylphie_admin_dev

# Runtime pool — used by the application at runtime. Row-level security (RLS)
# is enforced on drive_rules: this user can SELECT but cannot INSERT/UPDATE/DELETE.
# The system proposes rules to drive_rules_proposed; guardian approves via admin pool.
# Username for the application runtime user. Created by docker/postgres/init.sql in docker-compose.
POSTGRES_RUNTIME_USER=sylphie_app
# Password for the application runtime user. Created by docker/postgres/init.sql in docker-compose.
POSTGRES_RUNTIME_PASSWORD=sylphie_app_dev

# Max concurrent connections to PostgreSQL system DB. Tune based on feature parallelism.
POSTGRES_MAX_CONNECTIONS=10
# Timeout in milliseconds for idle connections before they are closed
POSTGRES_IDLE_TIMEOUT_MS=30000
# Timeout in milliseconds for acquiring a connection from the pool
POSTGRES_CONNECTION_TIMEOUT_MS=5000

# --- Grafeo (Self KG + Other KGs) ---
# Grafeo runs embedded inside the NestJS process. No separate container.
# Self KG (KG(Self)) holds Sylphie's self-model. Other KGs are per-person
# (one instance per personId, e.g. person_jim). These are completely isolated
# from each other and from the WKG — no shared edges, no cross-contamination.

# Filesystem path where the Self Knowledge Graph (Grafeo) will persist
# Relative path is from the application working directory (project root)
GRAFEO_SELF_KG_PATH=./data/self-kg

# Filesystem path where Other Knowledge Graphs (Grafeo) will persist
# One subdirectory per person (person_jim, person_alice, etc.)
GRAFEO_OTHER_KG_PATH=./data/other-kgs

# Maximum nodes per knowledge graph. When exceeded, oldest nodes are evicted.
# Tune based on expected knowledge base size and memory constraints.
GRAFEO_MAX_NODES_PER_KG=10000

# --- Planning Subsystem ---
# Planning subsystem configuration: researches failure patterns, simulates outcomes,
# validates plans via LLM constraint checking, and creates procedure nodes.

# Maximum number of plans that can be created within a single rate-limit window
PLANNING_MAX_PLANS_PER_WINDOW=3

# Duration of the rate-limit window in milliseconds (default: 1 hour)
PLANNING_WINDOW_DURATION_MS=3600000

# Maximum number of active procedures (created but not yet evaluated by Decision Making)
PLANNING_MAX_ACTIVE_PLANS=10

# Maximum token budget per plan for LLM constraint validation
PLANNING_MAX_TOKENS_PER_PLAN=4000

# Maximum opportunities the priority queue can hold
PLANNING_QUEUE_MAX_SIZE=50

# Rate at which opportunity priority decays per hour [0.0, 1.0]
PLANNING_QUEUE_DECAY_RATE_PER_HOUR=0.10

# Minimum priority threshold below which opportunities are dropped from the queue
PLANNING_QUEUE_MIN_PRIORITY=0.01

# Number of opportunities after system start before cold-start dampening is disabled
PLANNING_COLD_START_THRESHOLD=100

# Dampening multiplier applied during cold start [0.0, 1.0]
PLANNING_COLD_START_INITIAL_DAMPENING=0.8

# Research time window in days for querying historical failure data
PLANNING_RESEARCH_TIME_WINDOW_DAYS=7

# Minimum number of failures required to establish sufficient evidence
PLANNING_MIN_FAILURES_FOR_EVIDENCE=2

# Minimum expected value threshold for a simulated outcome to be considered viable
PLANNING_SIMULATION_MIN_EXPECTED_VALUE=0.3

# Maximum number of times a proposal can be revised before giving up
PLANNING_MAX_PROPOSAL_REVISIONS=2

# Interval in milliseconds for processing queued opportunities
PLANNING_PROCESSING_INTERVAL_MS=5000

# --- LLM Provider ---
# The LLM is Sylphie's voice, not her mind. Used only for Type 2 deliberation,
# Learning refinement, and Communication response generation.
# Provider: 'ollama' (default, local inference) or 'anthropic' (Claude API)
LLM_PROVIDER=ollama

# Maximum tokens per LLM request. Affects response length and token cost.
LLM_MAX_TOKENS=4096

# Sampling temperature for LLM responses. Range 0.0-1.0.
LLM_TEMPERATURE=0.7

# Enable cost tracking for LLM API calls (true/false)
LLM_COST_TRACKING_ENABLED=true

# --- Ollama (Local Inference) ---
# Default provider. Two-model architecture: GPU for reasoning, CPU for conversation.
OLLAMA_BASE_URL=http://localhost:11434
# GPU model: slow but capable. Type 2 deliberation, Learning, Planning.
OLLAMA_GPU_MODEL=gemma3:27b
# CPU model: fast and lightweight. Conversation response generation.
OLLAMA_CPU_MODEL=qwen2.5:7b

# --- Anthropic (Cloud Fallback) ---
# Used when LLM_PROVIDER=anthropic. Requires API key.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# --- Voice ---
# STT (Deepgram) for perception layer. TTS (ElevenLabs) for communication output.

# Deepgram API key for speech-to-text
DEEPGRAM_API_KEY=

# ElevenLabs API key for text-to-speech
ELEVENLABS_API_KEY=
# ElevenLabs voice ID
ELEVENLABS_VOICE_ID=
# ElevenLabs model ID. Default: eleven_monolingual_v1
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# Legacy OpenAI voice config (kept for backward compatibility during migration)
OPENAI_API_KEY=
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova

# --- Web Subsystem (HTTP, WebSocket, Graph Viz, Telemetry) ---
# Configuration for the NestJS web server and all client-facing features.
# The web subsystem provides HTTP API, real-time WebSocket communication,
# knowledge graph visualization, and frontend telemetry collection.

# HTTP port where the NestJS backend listens for requests
WEB_HTTP_PORT=3000

# HTTP host/interface to bind to. Use 0.0.0.0 to listen on all interfaces.
WEB_HTTP_HOST=0.0.0.0

# CORS origin allowed to access the API from browser. For development, typically the vite dev server.
# In production, set to the frontend domain (e.g., https://example.com)
WEB_CORS_ORIGIN=http://localhost:5173

# Whether credentials (cookies, Authorization headers) are allowed in cross-origin requests
WEB_CORS_CREDENTIALS=true

# URL path prefix for WebSocket connections. Clients connect to ws://host:port/ws
WEB_WS_PATH_PREFIX=/ws

# Maximum concurrent WebSocket client connections allowed. Prevents resource exhaustion.
WEB_WS_MAX_CLIENTS=100

# WebSocket heartbeat ping interval in milliseconds. Detects stale connections and prevents idle timeouts.
WEB_WS_HEARTBEAT_INTERVAL_MS=30000

# Development mode flag. When true, enables debug logging, relaxed validation, etc.
WEB_DEVELOPMENT_MODE=true

# Knowledge graph visualization settings - maximum traversal depth from a root node
WEB_GRAPH_MAX_DEPTH=3

# Knowledge graph visualization settings - maximum nodes returned in a single query
WEB_GRAPH_MAX_NODES=200

# Knowledge graph visualization settings - query execution timeout in milliseconds
WEB_GRAPH_QUERY_TIMEOUT_MS=5000

# Frontend telemetry batching interval in milliseconds. Events are buffered and flushed at this interval.
WEB_TELEMETRY_BATCH_INTERVAL_MS=500

# Frontend telemetry maximum batch size. Events are flushed when batch size is reached, whichever comes first.
WEB_TELEMETRY_MAX_BATCH_SIZE=50

# Health check endpoint result caching TTL in milliseconds. Prevents excessive database queries.
WEB_HEALTH_CACHE_TTL_MS=30000

# Individual health check timeout in milliseconds. Slow checks are marked as degraded.
WEB_HEALTH_CHECK_TIMEOUT_MS=500
