# ==========================================
# Sylphie — Railway Environment Variables
# ==========================================
# Set these in the Railway dashboard under your service's Variables tab.
# Railway auto-injects PORT — do not set it manually.
#
# Railway private networking:
#   Services within the same project communicate via
#   <service-name>.railway.internal:<internal-port>
#   These are NOT accessible from the public internet.

# --- Application ---
NODE_ENV=production
APP_ENV=production
APP_LOG_LEVEL=info
SESSION_ID=prod-session-001

# --- Neo4j (World Knowledge Graph) ---
# Railway service: deploy neo4j:5-community image, name it "neo4j-world"
NEO4J_WORLD_URI=bolt://neo4j-world.railway.internal:7687
NEO4J_WORLD_USER=neo4j
NEO4J_WORLD_PASSWORD=
NEO4J_WORLD_DATABASE=neo4j
NEO4J_WORLD_MAX_CONNECTION_POOL_SIZE=50
NEO4J_WORLD_CONNECTION_TIMEOUT_MS=5000

# --- Neo4j (Self Knowledge Graph) ---
# Railway service: deploy neo4j:5-community image, name it "neo4j-self"
NEO4J_SELF_URI=bolt://neo4j-self.railway.internal:7687
NEO4J_SELF_USER=neo4j
NEO4J_SELF_PASSWORD=
NEO4J_SELF_DATABASE=neo4j
NEO4J_SELF_MAX_CONNECTION_POOL_SIZE=50
NEO4J_SELF_CONNECTION_TIMEOUT_MS=5000

# --- Neo4j (Other Knowledge Graph) ---
# Railway service: deploy neo4j:5-community image, name it "neo4j-other"
NEO4J_OTHER_URI=bolt://neo4j-other.railway.internal:7687
NEO4J_OTHER_USER=neo4j
NEO4J_OTHER_PASSWORD=
NEO4J_OTHER_DATABASE=neo4j
NEO4J_OTHER_MAX_CONNECTION_POOL_SIZE=50
NEO4J_OTHER_CONNECTION_TIMEOUT_MS=5000

# --- Neo4j (PKG — optional, leave blank to skip) ---
# NEO4J_PKG_URI=
# NEO4J_PKG_USER=
# NEO4J_PKG_PASSWORD=
# NEO4J_PKG_DATABASE=neo4j

# --- TimescaleDB (Event Backbone) ---
# Railway service: deploy timescale/timescaledb:latest-pg17 image, name it "timescaledb"
TIMESCALE_HOST=timescaledb.railway.internal
TIMESCALE_PORT=5432
TIMESCALE_DB=sylphie_events
TIMESCALE_USER=sylphie
TIMESCALE_PASSWORD=
TIMESCALE_MAX_CONNECTIONS=20
TIMESCALE_IDLE_TIMEOUT_MS=30000
TIMESCALE_CONNECTION_TIMEOUT_MS=5000
TIMESCALE_RETENTION_DAYS=90
TIMESCALE_COMPRESSION_DAYS=7

# --- PostgreSQL System DB (Drive Rules, Settings, Users) ---
# Railway service: use the Railway PostgreSQL plugin, or deploy postgres:17 as "postgres"
POSTGRES_HOST=postgres.railway.internal
POSTGRES_PORT=5432
POSTGRES_DB=sylphie_system
POSTGRES_ADMIN_USER=sylphie_admin
POSTGRES_ADMIN_PASSWORD=
POSTGRES_RUNTIME_USER=sylphie_app
POSTGRES_RUNTIME_PASSWORD=
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECTION_TIMEOUT_MS=5000

# Prisma (uses admin credentials)
DATABASE_URL=postgresql://sylphie_admin:PASSWORD@postgres.railway.internal:5432/sylphie_system

# --- DeepSeek API ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_MEDIUM_MODEL=deepseek-chat

# --- Ollama (leave blank if using DeepSeek for all tiers) ---
# OLLAMA_HOST=
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_MODEL_QUICK=qwen2.5:3b
# OLLAMA_MODEL_MEDIUM=qwen2.5:7b
# OLLAMA_MODEL_DEEP=gpt-oss:20b

# --- Deepgram (Speech-to-Text) ---
DEEPGRAM_API_KEY=

# --- ElevenLabs (Text-to-Speech) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Auth ---
JWT_SECRET=

# --- Perception (external GPU server — leave blank to disable) ---
# PERCEPTION_HOST=http://your-gpu-server:8430

# --- SearXNG ---
# Railway service: deploy searxng/searxng:latest image, name it "searxng"
# Leave blank to disable web search (deliberation degrades gracefully)
SEARXNG_URL=http://searxng.railway.internal:8080

# --- Drive Engine ---
# If running drive-server as a separate Railway service:
# DRIVE_ENGINE_WS_URL=ws://drive-server.railway.internal:3001
# If running locally within the same container (not yet supported):
DRIVE_ENGINE_PORT=3001
DRIVE_ENGINE_HOST=127.0.0.1
DRIVE_ENGINE_WS_URL=ws://localhost:3001

# --- CORS (only needed if frontend is deployed separately) ---
# CORS_ORIGIN=https://your-frontend.railway.app

# --- Verbose Logging ---
# VERBOSE=1
