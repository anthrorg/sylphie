{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "../..",
    "paths": {
      "@sylphie/shared": ["packages/shared/src"],
      "@sylphie/shared/*": ["packages/shared/src/*"],
      "@sylphie/drive-engine": ["packages/drive-engine/src"],
      "@sylphie/drive-engine/*": ["packages/drive-engine/src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
