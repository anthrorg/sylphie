{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp"]
    },
    "codebase-pkg": {
      "command": "node",
      "args": ["../co-being/codebase-pkg/dist/mcp-server/index.js"],
      "env": {
        "CODEBASE_PKG_NEO4J_URI": "bolt://localhost:7689",
        "CODEBASE_PKG_NEO4J_USER": "neo4j",
        "CODEBASE_PKG_NEO4J_PASSWORD": "codebase-pkg-local"
      }
    }
  }
}
