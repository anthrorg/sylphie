    "pg": "^8.0.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.0.0",
    "dotenv-cli": "^7.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
