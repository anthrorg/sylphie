{
  "name": "@sylphie/drive-engine",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./drive-process/*": {
      "types": "./dist/drive-process/*.d.ts",
      "default": "./dist/drive-process/*.js"
    },
    "./ipc-channel/*": {
      "types": "./dist/ipc-channel/*.d.ts",
      "default": "./dist/ipc-channel/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npx tsx src/drive-process/opportunity-queue.spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@sylphie/shared": "0.0.1",
    "pg": "^8.0.0",
    "rxjs": "^7.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pg": "^8.0.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  }
}
