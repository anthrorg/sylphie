{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "removeComments": true,
    "paths": {
      "@sylphie/shared": ["packages/shared/src"],
      "@sylphie/shared/*": ["packages/shared/src/*"],
      "@sylphie/decision-making": ["packages/decision-making/src"],
      "@sylphie/decision-making/*": ["packages/decision-making/src/*"],
      "@sylphie/drive-engine": ["packages/drive-engine/src"],
      "@sylphie/drive-engine/*": ["packages/drive-engine/src/*"],
      "@sylphie/learning": ["packages/learning/src"],
      "@sylphie/learning/*": ["packages/learning/src/*"],
      "@sylphie/planning": ["packages/planning/src"],
      "@sylphie/planning/*": ["packages/planning/src/*"]
    },
    "baseUrl": "."
  }
}
